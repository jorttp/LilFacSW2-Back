# Copia este archivo: cp .env.example .env
# Rellena los valores y NUNCA subas .env al repositorio

# PostgreSQL
POSTGRES_DB=DbLilfac
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# Vault (solo el token; las credenciales de la app las carga Vault)
VAULT_TOKEN=mi-token-dev

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123

# Grafana
GRAFANA_ADMIN_PASSWORD=admin123
